/control/verbose 2
/run/verbose 1
/event/verbose 0
/tracking/verbose 0

/cfg/setRunMode StageC_OpticalRVE
# Generate this split file with:
# python3 stageC_make_zns_sources.py --ratio-tag 1-1.5 --thickness-range 500-500 --split-by-placement
/cfg/setOpticalSourceCsv ../Input/alpha_li_steps/1-1.5/by_placement/500/500_placement_f_0.64_0011_zns_step_sources.csv
/cfg/setSourceSampling uniformAlongStep
/cfg/setSamplePhotonsPerStep 1
# matrix_n matrix_abs_um BN_n BN_abs_um ZnS_n ZnS_abs_um
# Replace these placeholder values with measured/fitted optical parameters.
/cfg/setOpticalParams 1.5 1000000 2.1 10 2.36 50

/run/initialize

# Smoke test: run a small number first. Increase after outputs look sane.
/run/beamOn 10000
